{
  "expo": {
    "name": "Vibely",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.vibelymeet.vibely",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0c"
    },
    "ios": {
      "bundleIdentifier": "com.vibelymeet.vibely",
      "appleTeamId": "W38S57AM55",
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "audio"
        ],
        "NSCameraUsageDescription": "Vibely uses your camera when you choose to join video dates, record Vibe Videos or chat clips, take profile photos, or submit verification selfies.",
        "NSMicrophoneUsageDescription": "Vibely uses your microphone when you choose to join video dates, record Vibe Videos or chat clips, and send voice messages.",
        "NSPhotoLibraryUsageDescription": "Vibely only uses the photos and videos you choose for profile photos, saved-video uploads, and chat media.",
        "NSLocationWhenInUseUsageDescription": "Vibely uses your location while the app is open, when you choose location features, to show nearby events and people.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Vibely uses your location when you choose location features to show nearby events and people.",
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.vibelymeet.vibely.onesignal"
        ]
      }
    },
    "android": {
      "package": "com.vibelymeet.vibely",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.CAMERA",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@daily-co/config-plugin-rn-daily-js",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Vibely uses your camera when you choose to join video dates, record Vibe Videos or chat clips, take profile photos, or submit verification selfies.",
          "microphonePermission": "Vibely uses your microphone when you choose to join video dates, record Vibe Videos or chat clips, and send voice messages.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vibely only uses the photos and videos you choose for profile photos, saved-video uploads, and chat media.",
          "cameraPermission": "Vibely uses your camera when you choose to take profile photos, chat photos, and verification selfies."
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.vibelymeet.vibely.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.vibelymeet.vibely.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "5c6f619c-3eea-4cbc-82f8-52b3875e0bf9"
      },
      "router": {}
    }
  }
}
