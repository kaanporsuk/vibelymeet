# Vibely Mobile — required env for local run/dev.
# Copy to .env and fill in values. Do not commit .env.
#
# Same Supabase project as web (shared backend). Get from web .env or Supabase dashboard.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key_here

# Required for profile/event/avatar images: Bunny CDN hostname (no https://). Same value as web VITE_BUNNY_CDN_HOSTNAME.
# If unset, photos/... paths show a placeholder instead of loading from CDN.
EXPO_PUBLIC_BUNNY_CDN_HOSTNAME=cdn.vibelymeet.com
# Optional: if your Bunny pull zone requires a path prefix (e.g. storage zone name), set it. Same as web VITE_BUNNY_CDN_PATH_PREFIX.
# EXPO_PUBLIC_BUNNY_CDN_PATH_PREFIX=

# OneSignal App ID for push notifications (same app as web VITE_ONESIGNAL_APP_ID). Required for push.
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# RevenueCat: public API keys from RevenueCat dashboard. Required for in-app purchases; leave all unset to hide purchase UI.
# Prefer platform-specific keys (used on iOS and Android respectively). Fallback: single key for both.
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your-ios-public-api-key
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your-android-public-api-key
# EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-public-api-key

# Vibe video playback: Bunny Stream CDN hostname for HLS (no https://). Same as web VITE_BUNNY_STREAM_CDN_HOSTNAME.
EXPO_PUBLIC_BUNNY_STREAM_CDN_HOSTNAME=vz-5585ddfc-604.b-cdn.net

# Sentry (error tracking). Same DSN as web VITE_SENTRY_DSN. Leave unset to disable.
# EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# PostHog (analytics). Same as web VITE_POSTHOG_API_KEY and VITE_POSTHOG_HOST. Leave unset to disable.
# EXPO_PUBLIC_POSTHOG_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
