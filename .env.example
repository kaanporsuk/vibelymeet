# Vibely web (Vite) — public env only. Copy to .env and fill in. Do not commit .env.
# Anything with VITE_ is bundled into the client and must be safe to expose.

# Required for Supabase client (use PUBLISHABLE_KEY; ANON_KEY is legacy fallback)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# VITE_SUPABASE_ANON_KEY=your_legacy_anon_key_here

# Optional: CDN hostnames (Bunny)
# VITE_BUNNY_CDN_HOSTNAME=cdn.example.com
# Optional: set when Bunny pull zone serves storage under a path prefix. Must match server `BUNNY_CDN_PATH_PREFIX`.
# VITE_BUNNY_CDN_PATH_PREFIX=
# VITE_BUNNY_STREAM_CDN_HOSTNAME=stream-cdn.example.com
# Private chat Storage CDN is server-only. Do not expose `BUNNY_CHAT_STORAGE_*`
# through VITE_/EXPO_PUBLIC_; clients receive short-lived resolver-issued URLs.

# Optional: OneSignal. If unset, web push is disabled; there is no runtime fallback.
# VITE_ONESIGNAL_APP_ID=your-onesignal-app-id

# Optional: PostHog (analytics)
# VITE_POSTHOG_API_KEY=your-posthog-key
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Optional: Sentry (fallback in code if unset)
# VITE_SENTRY_DSN=your-sentry-dsn

# Public Turnstile site key for /delete-account and auth CAPTCHA token collection.
# This is safe for the browser; the secret key must stay server/provider-side.
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Optional: Supabase Edge Function Sentry monitoring
# SENTRY_DSN=your-server-side-sentry-dsn
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_FLUSH_TIMEOUT_MS=500

# Optional: Video Date launch acceleration flags. Web rollout defaults are on;
# set any of these to false to disable that slice explicitly.
VITE_VIDEO_DATE_ROOM_WARMUP_AFTER_READY=true
VITE_VIDEO_DATE_DAILY_PREWARM=true
VITE_VIDEO_DATE_DAILY_JOIN_PREWARM=true
VITE_VIDEO_DATE_DAILY_SOLO_PREJOIN=false
VITE_VIDEO_DATE_DAILY_BANDWIDTH_OPTIMIZED=false
VITE_VIDEO_DATE_DAILY_DEVICE_PREFERENCE_COOKIES=false

# Optional: app URL, Stripe publishable, RevenueCat (if ever used by web)
# VITE_APP_URL=https://www.vibelymeet.com
# VITE_STRIPE_PUBLISHABLE_KEY=pk_...
# VITE_REVENUECAT_IOS_API_KEY=...
# VITE_REVENUECAT_ANDROID_API_KEY=...

# Do NOT put these in VITE_* — they are server secrets, not for the browser:
# Twilio auth token, Resend API key, Supabase project ID, service role key, etc.
# Turnstile secret key, deletion rate-limit pepper, and deletion reauth provider
# secrets must stay server-only.
#
# Supabase Edge Function secrets for public account deletion:
# TURNSTILE_SECRET_KEY=...
# ACCOUNT_DELETION_RATE_LIMIT_PEPPER=...
#
# Supabase Edge Function secrets used by authenticated account deletion reauth:
# RESEND_API_KEY=...
# EMAIL_VERIFICATION_OTP_SECRET=...
# EMAIL_VERIFICATION_FROM_EMAIL=Vibely <hello@vibelymeet.com>
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_VERIFY_SERVICE_SID=...
#
# Supabase Edge Function secrets for new Chat Vibe Clips on Bunny Stream:
# BUNNY_CHAT_STREAM_LIBRARY_ID=664033
# BUNNY_CHAT_STREAM_API_KEY=...
# BUNNY_CHAT_STREAM_CDN_HOSTNAME=vz-f9687b64-5c9.b-cdn.net
# BUNNY_CHAT_STREAM_TOKEN_SECURITY_KEY=...
# Optional collection for Chat Vibe Clips:
# BUNNY_CHAT_STREAM_COLLECTION_ID=...
#
# Supabase Edge Function secrets for private chat Storage delivery:
# CHAT_MEDIA_DIRECT_CDN_ENABLED=true
# BUNNY_CHAT_STORAGE_CDN_HOSTNAME=vibely-chat-storage-hot.b-cdn.net
# BUNNY_CHAT_STORAGE_TOKEN_SECURITY_KEY=...
# CHAT_MEDIA_PROXY_SECRET=...
# Optional archive tier:
# BUNNY_CHAT_STORAGE_ARCHIVE_CDN_HOSTNAME=...
# BUNNY_CHAT_STORAGE_ARCHIVE_TOKEN_SECURITY_KEY=...
#
# Supabase Edge Function secrets for Video Date Daily:
# DAILY_API_KEY=...
# DAILY_DOMAIN=your-daily-domain.daily.co
# DAILY_WEBHOOK_SECRET=...
# CRON_SECRET=...
# Optional local-only fallback label when running Supabase functions locally:
# ENVIRONMENT=local
# Optional Edge Function Sentry tracing for video-webhook:
# SENTRY_DSN=your-server-side-sentry-dsn
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_FLUSH_TIMEOUT_MS=500
